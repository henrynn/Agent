RESOURCE_GROUP=rg-hybrid-agent-poc
LOCATION=eastus
ACR_NAME=hybridagentacr001
IMAGE_REPOSITORY=openclaw-aca
# Optional when you build and deploy in one command. If omitted, the script generates a timestamped tag.
IMAGE_TAG=
# Optional override to skip ACR build and deploy a public image directly.
CONTAINER_IMAGE=
SOURCE_CONTEXT=https://github.com/openclaw/openclaw.git#main
DOCKERFILE=aca-wrapper/Dockerfile
USE_LOCAL_CONTEXT=true
LOCAL_CONTEXT_PATH=openclaw

MANAGED_ENVIRONMENT_NAME=acae-hybrid-agent-poc
CONTAINER_APP_NAME=openclaw-cloud
STORAGE_ACCOUNT_NAME=sthybridagentpoc001
FILE_SHARE_NAME=openclawstate
USER_ASSIGNED_IDENTITY_NAME=id-openclaw-pull
GATEWAY_TOKEN=replace-with-a-long-random-token
OPENCLAW_BASE_URL=https://smartapims.azure-api.net/openai
OPENCLAW_ENV_KEY=AZURE_OPENAI_API_KEY
# For APIM or other Azure fronts exposing the OpenAI-compatible /openai/responses route,
# keep the provider id as azure but let the config generator emit openai-responses.
OPENCLAW_WIRE_API=responses
OPENCLAW_MODEL_PROVIDER=azure
OPENCLAW_MODEL_NAME=gpt-5.4
OPENCLAW_MODEL_REASONING_EFFORT=medium
AZURE_OPENAI_API_KEY=replace-with-your-azure-openai-api-key
OPENAI_API_KEY=replace-with-your-openai-api-key
