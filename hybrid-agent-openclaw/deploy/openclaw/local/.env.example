OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_GATEWAY_TOKEN=replace-with-a-long-random-token
OPENCLAW_BASE_URL=https://smartapims.azure-api.net/openai
OPENCLAW_ENV_KEY=AZURE_OPENAI_API_KEY
# For APIM or other Azure fronts exposing the OpenAI-compatible /openai/responses route,
# keep the provider id as azure but let the config generator emit openai-responses.
OPENCLAW_WIRE_API=responses
OPENCLAW_MODEL_PROVIDER=azure
OPENCLAW_MODEL_NAME=gpt-5.4
OPENCLAW_MODEL_REASONING_EFFORT=medium
AZURE_OPENAI_API_KEY=replace-with-your-azure-openai-api-key
OPENAI_API_KEY=replace-with-your-openai-api-key
